{
  "name": "qing-web-translate-manager",
  "version": "1.0.0",
  "description": "浏览器端翻译管理工具",
  "main": "backend/server.js",
  "type": "module",
  "scripts": {
    "setup": "node setup.js",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "node backend/server.js",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "node backend/server.js",
    "install:all": "npm install && cd frontend && npm install"
  },
  "keywords": ["translation", "manager", "web", "browser"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "fs-extra": "^11.1.1",
    "esbuild": "^0.25.9",
    "prettier": "^3.3.3",
    "acorn": "^8.12.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}